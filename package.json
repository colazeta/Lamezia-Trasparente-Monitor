{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "test": "pnpm -r --if-present run test",
    "albo:fetch": "pnpm --filter @workspace/scripts run fetch:albo",
    "climate:lamezia": "node scripts/build-lamezia-climate-data.mjs",
    "smoke:v0-static-fallback": "pnpm --filter @workspace/lamezia-trasparente run build && node scripts/check-v0-static-fallback.mjs",
    "hook:pr-guard": "node scripts/hooks/pr-guard.mjs",
    "hook:source-metadata": "node scripts/hooks/source-metadata-check.mjs",
    "hook:zero-cost": "node scripts/hooks/zero-cost-policy-check.mjs",
    "organi:qa": "pnpm --filter @workspace/scripts run check:organi",
    "organi:qa:history": "pnpm --filter @workspace/scripts run check:organi:history",
    "organi:qa:live": "pnpm --filter @workspace/scripts run check:organi:live",
    "trame:discover": "node scripts/legalita/trame/discover_trame_program.mjs && node scripts/legalita/trame/discover_trame_videos.mjs",
    "trame:transcripts:probe": "node scripts/legalita/trame/fetch_trame_transcripts.mjs",
    "trame:cards": "node scripts/legalita/trame/extract_trame_public_cards.mjs",
    "trame:qa": "node scripts/legalita/trame/qa_trame_section.mjs",
    "v0:readiness": "node scripts/check-v0-readiness.mjs"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
