# =============================================================================
# rendiamoLameziaTrasparente — variabili d'ambiente
# Copia questo file in .env e compila i valori per l'ambiente di sviluppo.
# NON committare mai il file .env con valori reali.
# In produzione, configura le variabili tramite i Secrets di Replit.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------

# Stringa di connessione PostgreSQL (obbligatoria per avviare l'api-server)
DATABASE_URL=postgresql://user:password@localhost:5432/lamezia_dev

# Stringa di connessione al database di test (usata dai test vitest dell'api-server)
# Se non impostata, i test che richiedono un DB reale vengono saltati
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/lamezia_test

# -----------------------------------------------------------------------------
# API SERVER
# -----------------------------------------------------------------------------

# Porta su cui ascolta il server Express (default: 5000 in dev, assegnata da Replit in prod)
PORT=5000

# Ambiente di esecuzione: "development" | "production"
NODE_ENV=development

# Livello di log Pino: "trace" | "debug" | "info" | "warn" | "error" | "fatal"
# In dev viene usato pino-pretty per output leggibile
LOG_LEVEL=info

# Token segreto per proteggere le route di ingestione dati (/api/ingest/*)
# Deve essere lo stesso valore impostato nel client di ingestione
INGEST_API_TOKEN=scegli-un-token-sicuro

# Scheduler periodico embedded di ingestion. Lasciare disabilitato in produzione
# per avviare solo API, migrazioni e schema check. Valori abilitanti espliciti:
# "local", "development"/"dev" o "legacy". Valori disabilitanti: "disabled", "off", "false", "0".
INGESTION_SCHEDULER_MODE=disabled

# URL pubblico del sito web (usato per generare link nelle email e nei feed RSS)
# Es. https://lamezia.example.com — senza slash finale
PUBLIC_BASE_URL=http://localhost:8081

# -----------------------------------------------------------------------------
# EMAIL — Resend
# -----------------------------------------------------------------------------

# Chiave API Resend per l'invio di email (notifiche cittadini, alert operativi)
RESEND_API_KEY=re_xxxxxxxx

# Indirizzo mittente verificato su Resend (deve corrispondere al dominio autorizzato)
RESEND_FROM_EMAIL=noreply@example.com

# Indirizzo email per gli alert operativi (es. errori di migrazione, anomalie)
# Se non impostato, gli alert vengono solo loggati
OPS_ALERT_EMAIL=ops@example.com

# -----------------------------------------------------------------------------
# OBJECT STORAGE — Google Cloud Storage (via sidecar Replit)
# -----------------------------------------------------------------------------

# Percorsi GCS per i file pubblici (allegati atti, dataset open data)
# Formato: bucket/path/prefix (separati da virgola per percorsi multipli)
PUBLIC_OBJECT_SEARCH_PATHS=my-bucket/public

# Directory GCS per i file privati (foto monitoraggio civico, upload cittadini)
# Formato: bucket/path/prefix
PRIVATE_OBJECT_DIR=my-bucket/private

# -----------------------------------------------------------------------------
# INTEGRAZIONE OPENAI (via proxy Replit AI Integrations)
# -----------------------------------------------------------------------------

# Chiave API OpenAI (o chiave del proxy Replit AI Integrations)
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...

# Base URL del proxy Replit (lasciare vuoto per usare direttamente OpenAI)
AI_INTEGRATIONS_OPENAI_BASE_URL=

# -----------------------------------------------------------------------------
# REPLIT — variabili di piattaforma (impostate automaticamente in Replit)
# -----------------------------------------------------------------------------

# Identità del Repl — usata per autenticarsi con il sidecar GCS di Replit
# Impostata automaticamente dall'ambiente Replit; non serve settarla in .env
# REPL_IDENTITY=

# Hostname del sidecar Replit Connectors (es. 127.0.0.1:1106)
# Impostata automaticamente dall'ambiente Replit
# REPLIT_CONNECTORS_HOSTNAME=

# Dominio pubblico del Repl (es. xxxx.replit.dev)
# Impostato automaticamente dall'ambiente Replit
# REPLIT_DEV_DOMAIN=

# Token di rinnovo per il Repl web (usato internamente)
# WEB_REPL_RENEWAL=

# -----------------------------------------------------------------------------
# SORGENTI DATI ESTERNE (opzionali — se non impostati, l'ingestione corrispondente è disabilitata)
# -----------------------------------------------------------------------------

# URL del feed CSV dei progetti ITALIADOMANI (PNRR — localizzazione)
ITALIADOMANI_LOC_CSV_URL=https://...

# URL del feed CSV dei progetti ITALIADOMANI (PNRR — progetti)
ITALIADOMANI_PROJ_CSV_URL=https://...

# URL del feed open data ANBSC (Agenzia Nazionale Beni Sequestrati e Confiscati)
ANBSC_OPENDATA_URL=https://...

# Codice del comune target per il filtro ANBSC (es. nome o codice ISTAT)
ANBSC_TARGET_COMUNE=Lamezia Terme

# -----------------------------------------------------------------------------
# APP MOBILE EXPO (solo per lo sviluppo locale dell'app mobile)
# -----------------------------------------------------------------------------

# Dominio pubblico del Repl — passato automaticamente dallo script dev dell'app mobile
# EXPO_PUBLIC_DOMAIN=xxxx.replit.dev
