{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lamezia-trasparente.local/schemas/istat_sezioni_censimento_lamezia.metadata.schema.json",
  "title": "ISTAT Lamezia census-section layer metadata",
  "type": "object",
  "required": [
    "sourceInstitution",
    "sourceDataset",
    "sourceYear",
    "territorialLevel",
    "municipality",
    "istatMunicipalCode",
    "processingDate",
    "verificationStatus",
    "knownLimits",
    "publicLabel",
    "warning"
  ],
  "properties": {
    "sourceInstitution": {
      "const": "ISTAT"
    },
    "sourceDataset": {
      "type": "string"
    },
    "sourceDatasetDetails": {
      "type": "object"
    },
    "sourceYear": {
      "type": "string"
    },
    "sourceYearDetails": {
      "type": "object"
    },
    "territorialLevel": {
      "const": "sezione di censimento"
    },
    "municipality": {
      "const": "Lamezia Terme"
    },
    "istatMunicipalCode": {
      "const": "079160"
    },
    "processingDate": {
      "type": "string"
    },
    "verificationStatus": {
      "type": "string"
    },
    "knownLimits": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publicLabel": {
      "const": "Dato ufficiale ISTAT per sezione censuaria"
    },
    "warning": {
      "type": "string",
      "pattern": "catastali|catastale|censuari|censuarie"
    },
    "qa": {
      "type": "object",
      "properties": {
        "reportPath": {
          "type": "string"
        },
        "indicatorDictionaryPath": {
          "type": "string"
        },
        "populationValueCoverage": {
          "type": "object",
          "required": ["totalFeatures", "availableCount", "nullCount"],
          "properties": {
            "totalFeatures": {
              "const": 317
            },
            "availableCount": {
              "const": 246
            },
            "availableShare": {
              "type": "number"
            },
            "nullCount": {
              "const": 71
            },
            "nullShare": {
              "type": "number"
            },
            "zeroCount": {
              "type": "number"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
